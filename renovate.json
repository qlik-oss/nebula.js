{
  "extends": ["local>qlik-oss/renovate-config"],
  "circleci": {
    "ignoreDeps": []
  },
  "ignoreDeps": ["react-virtualized-auto-sizer"],
  "semanticCommits": true,
  "rangeStrategy": "bump",
  "regexManagers": [
    {
      "fileMatch": ["^commands/create/templates/.*/_package\\.json$"],
      "matchStrings": [
        "^\\s+\\\"(?<depName>@?[a-zA-Z0-9._/-]+)\\\"\\s*:\\s*\\\"(?<currentValue>[~^]?\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?)\\\""
      ],
      "datasourceTemplate": "npm"
    }
  ],
  "packageRules": [
    {
      "depTypeList": ["engines"],
      "enabled": false
    }
  ],
  "dependencyDashboard": true
}
